# ---- SAYFORGE environment ----

# Groq API key (server-side ONLY — never exposed to the browser).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Groq model id. Verify current ids at https://console.groq.com/docs/models
# (Groq deprecates models fast.) Fallback is llama-3.3-70b-versatile.
GROQ_MODEL=openai/gpt-oss-120b

# SAYMAN testnet RPC base. REST API lives under /api.
# Options: https://sayman.up.railway.app (higher block height, persists longer)
#      or  https://sayman.onrender.com
SAYMAN_RPC=https://sayman.up.railway.app

# Deployer wallet for `npm run deploy` (server-side CLI deploys).
# 64-hex secp256k1 private key. Leave empty to have the deploy script generate
# one and save it here; then fund the printed address with a little SAYN.
# NOTE: this is a secret — .env is gitignored and must never be committed.
DEPLOYER_PRIVATE_KEY=

# Port the Express server listens on (Render sets this automatically).
PORT=3001
