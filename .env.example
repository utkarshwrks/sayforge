# ---- SAYFORGE environment ----

# Groq API key (server-side ONLY — never exposed to the browser).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Groq model id. Verify current ids at https://console.groq.com/docs/models
# (Groq deprecates models fast.) Fallback is llama-3.3-70b-versatile.
GROQ_MODEL=openai/gpt-oss-120b

# SAYMAN testnet RPC base. REST API lives under /api.
# Railway node persists deployed contracts; the Render free node resets every ~30s.
SAYMAN_RPC=https://sayman.up.railway.app

# Port the Express server listens on (Render sets this automatically).
PORT=3001
