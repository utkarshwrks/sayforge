{
  "name": "sayforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SAYFORGE — AI smart-contract studio for the SAYMAN blockchain",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env NODE_ENV=development PORT=3001 node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "vite preview",
    "deploy": "node scripts/deploy.js",
    "deploy:wait": "node scripts/deploy.js --wait"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@noble/hashes": "^1.5.0",
    "@noble/secp256k1": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
